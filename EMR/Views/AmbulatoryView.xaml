<UserControl x:Class="EMR.Views.AmbulatoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
        mc:Ignorable="d"
        d:DesignHeight="650" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Add Doctor" Command="{Binding AddDoctorCommand}" 
                    Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Schedule Appointment" Command="{Binding AddAppointmentCommand}" 
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Complete" Command="{Binding CompleteAppointmentCommand}" 
                    Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Cancel" Command="{Binding CancelAppointmentCommand}" 
                    Style="{StaticResource DangerButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" 
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <!-- In AmbulatoryView.xaml, add after existing buttons -->
            <Button Content="Add Patient" Command="{Binding AddPatientCommand}" 
        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
        </StackPanel>

        <!-- Content -->
        <TabControl Grid.Row="1">
            <TabItem Header="Doctors">
                <DataGrid ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctor}"
                          AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding DoctorId}" Width="50"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="150"/>
                        <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="150"/>
                        <DataGridTextColumn Header="License" Binding="{Binding LicenseNumber}" Width="120"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120"/>
                        <DataGridTextColumn Header="Fee" Binding="{Binding ConsultationFee, StringFormat=C}" Width="100"/>
                        <DataGridCheckBoxColumn Header="Available" Binding="{Binding IsAvailable}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Appointments">
                <DataGrid ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}"
                          AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding AppointmentId}" Width="50"/>
                        <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="150"/>
                        <DataGridTextColumn Header="Doctor" Binding="{Binding DoctorName}" Width="150"/>
                        <DataGridTextColumn Header="Date &amp; Time" Binding="{Binding AppointmentDate, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding AppointmentType}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Patients">
                <DataGrid ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient}"
                          AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding PatientId}" Width="50"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="150"/>
                        <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="50"/>
                        <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="70"/>
                        <DataGridTextColumn Header="Blood Group" Binding="{Binding BloodGroup}" Width="90"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>