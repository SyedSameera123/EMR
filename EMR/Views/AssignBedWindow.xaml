<Window x:Class="EMR.Views.AssignBedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
        xmlns:vm="clr-namespace:EMR.ViewModels"
        mc:Ignorable="d"
        Title="AssignBedWindow" Height="650" Width="800"
         WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.DataContext>
        <vm:AssignBedViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🛏️ Assign Bed to Patient" FontSize="22" FontWeight="Bold" Foreground="#2196F3"/>
            <TextBlock Text="Admit a patient to a hospital bed" FontSize="12" Foreground="#666" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
            <StackPanel>
                <!-- Bed Info Card -->
                <Border Background="#E3F2FD" 
                        BorderBrush="#2196F3" 
                        BorderThickness="0,0,0,2"
                        CornerRadius="3"
                        Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding ShowBedInfo, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="Selected Bed" FontWeight="Bold" FontSize="11" Foreground="#1976D2" Margin="0,0,0,8"/>
                        <TextBlock FontSize="12">
                            <Run Text="Bed Number: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedBed.BedNumber, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="12">
                            <Run Text="Ward: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedBed.WardName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="12">
                            <Run Text="Floor: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedBed.Floor, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Text="Select Patient *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Patients}" 
                          SelectedItem="{Binding SelectedPatient}"
                          DisplayMemberPath="FullName"
                          Style="{StaticResource ComboBoxStyle}"/>
                <!-- ← NEW: Add Doctor Selection -->
                <TextBlock Text="Assign Doctor *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Doctors}" 
          SelectedItem="{Binding SelectedDoctor}"
          Style="{StaticResource ComboBoxStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock>
                    <Run Text="Dr. " FontWeight="SemiBold"/>
                    <Run Text="{Binding FirstName}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding LastName}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Specialization}" 
                          FontSize="11" Foreground="#666" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>


                <TextBlock Text="Admission Date *" Style="{StaticResource LabelStyle}" Margin="0,8,0,4"/>
                <DatePicker SelectedDate="{Binding AdmissionDate}" 
                           Height="36" FontSize="13" Padding="10,8"/>

                <TextBlock Text="Expected Discharge Date" Style="{StaticResource LabelStyle}"/>
                <DatePicker SelectedDate="{Binding ExpectedDischargeDate}" 
                           Height="36" FontSize="13" Padding="10,8"/>

                <TextBlock Text="Admission Reason *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding AdmissionReason, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"
                         Height="80" VerticalScrollBarVisibility="Auto"/>

                <!-- Patient Info Display -->
                <Border Background="#E8F5E9" 
                        BorderBrush="#4CAF50" 
                        BorderThickness="0,0,0,2"
                        CornerRadius="3"
                        Padding="12"
                        Margin="0,12,0,0"
                        Visibility="{Binding ShowPatientInfo, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="Patient Information" FontWeight="Bold" FontSize="11" Foreground="#2E7D32" Margin="0,0,0,8"/>
                        <TextBlock FontSize="12">
                            <Run Text="Name: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.FullName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="12">
                            <Run Text="Age: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.Age, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="12">
                            <Run Text="Blood Group: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.BloodGroup, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="12">
                            <Run Text="Phone: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.PhoneNumber, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Error Message -->
                <Border Background="#FFEBEE" BorderBrush="#F44336" BorderThickness="1" 
                        CornerRadius="3" Padding="12,8" Margin="0,12,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" 
                              Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Assign" 
                    Command="{Binding AssignCommand}"
                    Padding="35,10" FontSize="13" FontWeight="SemiBold"
                    Background="#4CAF50" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45A049"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2" Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Padding="35,10" FontSize="13" FontWeight="SemiBold"
                    Background="#607D8B" Foreground="White"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#546E7A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
