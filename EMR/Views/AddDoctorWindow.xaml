<Window x:Class="EMR.Views.AddDoctorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
         xmlns:vm="clr-namespace:EMR.ViewModels"
        mc:Ignorable="d"
        Title="AddDoctorWindow" Height="650" Width="800" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.DataContext>
        <vm:AddDoctorViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="👨‍⚕️ Add New Doctor" FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
            <TextBlock Text="Fill in the doctor details below" FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="First Name *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Last Name *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Specialization *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Specializations}" 
                          SelectedItem="{Binding SelectedSpecialization}"
                          Style="{StaticResource ComboBoxStyle}"/>

                <TextBlock Text="License Number *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding LicenseNumber, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Phone Number *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Consultation Fee *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding ConsultationFee, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Join Date *" Style="{StaticResource LabelStyle}"/>
                <DatePicker SelectedDate="{Binding JoinDate}" 
                           Height="40" FontSize="14" Padding="10"/>

                <CheckBox Content="Available for appointments" 
                          IsChecked="{Binding IsAvailable}"
                          Margin="0,15,0,0" FontSize="14"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                          Foreground="#F44336" 
                          Margin="0,15,0,0" 
                          TextWrapping="Wrap"
                          Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Save" 
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource SuccessButtonStyle}"
                    Width="120" Margin="0,0,10,0"/>

            <Button Grid.Column="2" Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="120"/>
        </Grid>
    </Grid>
</Window>
