<Window x:Class="EMR.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
        xmlns:vm="clr-namespace:EMR.ViewModels"
        mc:Ignorable="d"
        Title="LoginWindow" Height="650" Width="800" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <!-- Login Mode -->
        <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" MaxWidth="400">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoginMode}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="🏥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Hospital Management System" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#2196F3" Margin="0,0,0,10"/>
            <TextBlock Text="Login to your account" FontSize="14" 
                       HorizontalAlignment="Center" Foreground="#666" Margin="0,0,0,30"/>

            <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,10,0,5"/>
            <TextBox x:Name="UsernameTextBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource LoginTextBoxStyle}"/>

            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,15,0,5"/>
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource LoginPasswordBoxStyle}"/>

            <TextBlock x:Name="ErrorText" Text="{Binding ErrorMessage}" Foreground="#F44336" 
                       Margin="0,15,0,0" TextWrapping="Wrap" FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button x:Name="LoginButton" Content="Login" Click="LoginButton_Click"
                    Style="{StaticResource LoginButtonStyle}" Margin="0,25,0,15"/>

            <Separator Margin="0,10"/>

            <Button Content="Create New Account" Command="{Binding SwitchToRegisterCommand}"
                    Style="{StaticResource LinkButtonStyle}" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Register Mode -->
        <ScrollViewer x:Name="RegisterPanel" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoginMode}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel MaxWidth="400" Margin="0,10">
                <TextBlock Text="Create New Account" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <TextBox Text="{Binding RegUsername, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource LoginTextBoxStyle}"/>

                <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox Text="{Binding RegEmail, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource LoginTextBoxStyle}"/>

                <TextBlock Text="First Name *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox Text="{Binding RegFirstName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource LoginTextBoxStyle}"/>

                <TextBlock Text="Last Name *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox Text="{Binding RegLastName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource LoginTextBoxStyle}"/>

                <TextBlock Text="Phone Number" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox Text="{Binding RegPhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource LoginTextBoxStyle}"/>

                <TextBlock Text="Role *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <ComboBox ItemsSource="{Binding Roles}" 
                          SelectedItem="{Binding SelectedRole}"
                          DisplayMemberPath="RoleName"
                          Height="40" Padding="10" FontSize="14" BorderBrush="#CCC"/>

                <TextBlock Text="Password *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <PasswordBox x:Name="RegPasswordBox" Style="{StaticResource LoginPasswordBoxStyle}"/>

                <TextBlock Text="Confirm Password *" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <PasswordBox x:Name="RegConfirmPasswordBox" Style="{StaticResource LoginPasswordBoxStyle}"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" 
                           Margin="0,15,0,0" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button x:Name="RegisterButton" Content="Register" Click="RegisterButton_Click"
                        Style="{StaticResource RegisterButtonStyle}" Margin="0,20,0,10"/>

                <Button Content="← Back to Login" Command="{Binding SwitchToLoginCommand}"
                        Style="{StaticResource LinkButtonStyle}" Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
