<Window x:Class="EMR.Views.ScheduleAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
         xmlns:vm="clr-namespace:EMR.ViewModels"
        mc:Ignorable="d"
        Title="ScheduleAppointmentWindow" Height="650" Width="800" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.DataContext>
        <vm:ScheduleAppointmentViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📅 Schedule New Appointment" FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
            <TextBlock Text="Create a new appointment for a patient" 
                      FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Select Patient *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Patients}" 
                          SelectedItem="{Binding SelectedPatient}"
                          DisplayMemberPath="FullName"
                          Style="{StaticResource ComboBoxStyle}"/>

                <TextBlock Text="Select Doctor *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Doctors}" 
                          SelectedItem="{Binding SelectedDoctor}"
                          DisplayMemberPath="FullName"
                          Style="{StaticResource ComboBoxStyle}"/>

                <TextBlock Text="Appointment Date *" Style="{StaticResource LabelStyle}"/>
                <DatePicker SelectedDate="{Binding AppointmentDate}" 
                           Height="40" FontSize="14" Padding="10"/>

                <TextBlock Text="Appointment Time *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding TimeSlots}" 
                          SelectedItem="{Binding SelectedTimeSlot}"
                          Style="{StaticResource ComboBoxStyle}"/>

                <TextBlock Text="Appointment Type *" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding AppointmentTypes}" 
                          SelectedItem="{Binding SelectedAppointmentType}"
                          Style="{StaticResource ComboBoxStyle}"/>

                <TextBlock Text="Reason for Visit *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"
                         Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>

                <!-- Doctor Info Display -->
                <Border Background="#E3F2FD" 
                        BorderBrush="#2196F3" 
                        BorderThickness="0,0,0,2"
                        CornerRadius="4"
                        Padding="15"
                        Margin="0,15,0,0"
                        Visibility="{Binding ShowDoctorInfo, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="Doctor Information" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>
                        <TextBlock>
                            <Run Text="Name: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedDoctor.FullName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,5,0,0">
                            <Run Text="Specialization: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedDoctor.Specialization, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,5,0,0">
                            <Run Text="Consultation Fee: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedDoctor.ConsultationFee, StringFormat=C, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Patient Info Display -->
                <Border Background="#E8F5E9" 
                        BorderBrush="#4CAF50" 
                        BorderThickness="0,0,0,2"
                        CornerRadius="4"
                        Padding="15"
                        Margin="0,10,0,0"
                        Visibility="{Binding ShowPatientInfo, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="Patient Information" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,10"/>
                        <TextBlock>
                            <Run Text="Name: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.FullName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,5,0,0">
                            <Run Text="Phone: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.PhoneNumber, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,5,0,0">
                            <Run Text="Blood Group: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedPatient.BloodGroup, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                          Foreground="#F44336" 
                          Margin="0,15,0,0" 
                          TextWrapping="Wrap"
                          Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Schedule" 
                    Command="{Binding ScheduleCommand}"
                    Style="{StaticResource SuccessButtonStyle}"
                    Width="120" Margin="0,0,10,0"/>

            <Button Grid.Column="2" Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="120"/>
        </Grid>
    </Grid>
</Window>
