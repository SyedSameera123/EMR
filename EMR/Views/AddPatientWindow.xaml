<Window x:Class="EMR.Views.AddPatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
        xmlns:vm="clr-namespace:EMR.ViewModels"
        mc:Ignorable="d"
        Title="AddPatientWindow" Height="650" Width="800"
         WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.DataContext>
        <vm:AddPatientViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="👤 Add New Patient" FontSize="22" FontWeight="Bold" Foreground="#2196F3"/>
            <TextBlock Text="Register a new patient in the system" FontSize="12" Foreground="#666" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Scrollable Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
            <StackPanel>
                <!-- Personal Information -->
                <Border Background="#E3F2FD" Style="{StaticResource SectionHeaderStyle}">
                    <TextBlock Text="PERSONAL INFORMATION" FontWeight="Bold" FontSize="11" Foreground="#1976D2"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="First Name *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Last Name *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Date of Birth *" Style="{StaticResource LabelStyle}"/>
                        <DatePicker SelectedDate="{Binding DateOfBirth}" 
                                   Height="36" FontSize="13" Padding="10,8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Gender *" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Genders}" 
                                  SelectedItem="{Binding SelectedGender}"
                                  Style="{StaticResource ComboBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Blood Group *" Style="{StaticResource LabelStyle}" Margin="0,4,0,4"/>
                <ComboBox ItemsSource="{Binding BloodGroups}" 
                          SelectedItem="{Binding SelectedBloodGroup}"
                          Style="{StaticResource ComboBoxStyle}"/>

                <!-- Contact Information -->
                <Border Background="#E8F5E9" Style="{StaticResource SectionHeaderStyle}">
                    <TextBlock Text="CONTACT INFORMATION" FontWeight="Bold" FontSize="11" Foreground="#388E3C"/>
                </Border>

                <TextBlock Text="Phone Number *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Address *" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"
                         Height="56" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="City *" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="State" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding State, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Emergency Contact -->
                <Border Background="#FFF3E0" Style="{StaticResource SectionHeaderStyle}">
                    <TextBlock Text="EMERGENCY CONTACT" FontWeight="Bold" FontSize="11" Foreground="#F57C00"/>
                </Border>

                <TextBlock Text="Emergency Contact Name" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding EmergencyContactName, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource TextBoxStyle}"/>

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Emergency Phone" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Relationship" Style="{StaticResource LabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Relationships}" 
                                  SelectedItem="{Binding SelectedRelationship}"
                                  Style="{StaticResource ComboBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Error Message -->
                <Border Background="#FFEBEE" BorderBrush="#F44336" BorderThickness="1" 
                        CornerRadius="3" Padding="12,8" Margin="0,15,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" 
                              Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Save" 
                    Command="{Binding SaveCommand}"
                    Padding="35,10" FontSize="13" FontWeight="SemiBold"
                    Background="#4CAF50" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45A049"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2" Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    Padding="35,10" FontSize="13" FontWeight="SemiBold"
                    Background="#607D8B" Foreground="White"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#546E7A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
