<UserControl x:Class="EMR.Views.CaretakerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMR.Views"
        mc:Ignorable="d"
        d:DesignHeight="650" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Add Caretaker" Command="{Binding AddCaretakerCommand}" 
                    Style="{StaticResource SuccessButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Edit" Command="{Binding UpdateCaretakerCommand}" 
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Delete" Command="{Binding DeleteCaretakerCommand}" 
                    Style="{StaticResource DangerButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Assign Patient" Command="{Binding AssignPatientCommand}" 
                    Style="{StaticResource WarningButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" 
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>

        <!-- Content -->
        <TabControl Grid.Row="1">
            <TabItem Header="Caretakers">
                <DataGrid ItemsSource="{Binding Caretakers}" SelectedItem="{Binding SelectedCaretaker}"
                          AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding CaretakerId}" Width="50"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="150"/>
                        <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="130"/>
                        <DataGridTextColumn Header="License" Binding="{Binding LicenseNumber}" Width="120"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120"/>
                        <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="80"/>
                        <DataGridTextColumn Header="Join Date" Binding="{Binding JoinDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Assignments">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" ItemsSource="{Binding Assignments}" SelectedItem="{Binding SelectedAssignment}"
                              AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F0F0F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding AssignmentId}" Width="50"/>
                            <DataGridTextColumn Header="Patient" Binding="{Binding PatientName}" Width="150"/>
                            <DataGridTextColumn Header="Caretaker" Binding="{Binding CaretakerName}" Width="150"/>
                            <DataGridTextColumn Header="Assigned Date" Binding="{Binding AssignedDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                            <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" Content="End Assignment" Command="{Binding EndAssignmentCommand}" 
                            HorizontalAlignment="Right" Margin="10" 
                            Style="{StaticResource DangerButtonStyle}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>